generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  budget    String
  details   String
  createdAt DateTime @default(now())
}

